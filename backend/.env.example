# Backend Environment Variables
# Copy this file to .env and fill in MongDB Atlas connection string

# MongoDB Connection (use MongoDB Atlas for production)
# Get free cluster at https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/servicehub?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Port (optional, defaults to 5000)
PORT=5000
